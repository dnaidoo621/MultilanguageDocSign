# Converted model binaries — generated by convert_model.py or the Dockerfile build step.
# Run: python convert_model.py --pair ko-en
models/**/*.bin
models/**/*.spm
models/**/*.json
models/**/*.txt
models/**/
# Allow the .gitkeep placeholder
!models/.gitkeep

# Training data — large HuggingFace corpus files are not committed
# data/legal_pairs.tsv (synthetic, small) IS committed
data/legal_filtered.tsv
data/legal_pairs_progress.json

# Python venv and cache
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# HuggingFace cache (if redirected here)
.cache/
